{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoltHurt",
  "version": "1.0.0",
  "identifier": "fun.cloverhub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VoltHurt",
        "decorations": false,
        "backgroundColor": "#0d0d0d",
        "width": 900,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}